# context.toon â€” Contexto del proyecto Rxpanel en formato TOON (Token-Oriented Object Notation)
# Formato compacto para consumo por LLMs. Espejo legible: CLAUDE.md, backend/CLAUDE.md, frontend/CLAUDE.md

project:
  name: Rxpanel
  type: monorepo
  description: "Panel de administraciÃ³n de sitios web: gestiona usuarios y sitios y edita su contenido (texto, colores, logos, archivos) a travÃ©s de un proxy autenticado hacia el sitio destino."
  managed_site_contract: "RecTrack y cualquier sitio con el mismo contrato de API"
  root: /home/dev/Documents/Rxcloud/Rxpanel
  parts[2]: backend,frontend
  orchestration: docker-compose.yml
  language_policy: "comentarios y docs en espaÃ±ol; identificadores de cÃ³digo en inglÃ©s"

docker:
  compose_file: docker-compose.yml
  services[3]{name,source,host_port,notes}:
    db,postgres:16-alpine,5432,"volumen postgres_data; healthcheck pg_isready"
    backend,build ./backend,8000,"uvicorn --reload; extra_host host.docker.internal"
    frontend,build ./frontend (target dev),3001,"Next.js dev en 3000 mapeado a host 3001"
  quickstart[3]:
    - "cp .env.example .env  # editar con valores reales"
    - "docker compose up -d"
    - "bash backend/seed.sh  # migraciones + datos de prueba"

backend:
  path: backend/
  guide: backend/CLAUDE.md
  stack:
    framework: FastAPI >=0.115
    runtime: Python 3.12
    orm: SQLAlchemy 2.0 async
    db_driver: asyncpg
    database: PostgreSQL 16
    migrations: Alembic
    auth: "JWT via python-jose (access + refresh)"
    passwords: bcrypt via passlib
    encryption: "Fernet (cryptography) para api_token"
    http_client: httpx
    validation: Pydantic v2 + pydantic-settings
    server: Uvicorn
  api_prefix: /api/v1
  layout:
    routes_dir: app/api/routes/
    business_logic: app/services/
    models_dir: app/models/
    schemas_dir: app/schemas/
    core_dir: app/core/
  models[5]{name,pk,fields,notes}:
    User,UUID,"email,username,hashed_password,role,is_active,is_deleted,created_at,updated_at","role admin|viewer|company_admin|company_editor|company_viewer; soft-deactivate is_active; soft-delete is_deleted; hashed_password nunca en respuestas"
    Site,int,"name,url,description,status,is_ssl,icon,icon_color,api_token,is_active,owner_id,created_at,updated_at","status active|inactive|maintenance|error; api_token Fernet-encrypted y nunca en respuestas; soft-delete is_active; owner_id FK users"
    ChangeLog,UUID,"site_id,user_id,section,change_type,payload_snapshot,created_at","change_type create|update|delete; payload_snapshot JSONB con el estado completo"
    RefreshToken,UUID,"token,user_id,is_revoked,expires_at,created_at",TTL 7 dias
    PasswordResetToken,UUID,"token,user_id,is_used,expires_at,created_at",token de recuperacion de contraseÃ±a
  auth_routes[6]{method,path,auth,description}:
    POST,/auth/register,none,Crea usuario con rol viewer
    POST,/auth/login,none,Devuelve access + refresh tokens
    POST,/auth/refresh,none,Renueva el access token
    POST,/auth/logout,none,Revoca el refresh token
    POST,/auth/recover,none,Genera token de recuperaciÃ³n
    POST,/auth/reset,none,Aplica nueva contraseÃ±a
  users_routes[8]{method,path,auth,description}:
    GET,/users/me,user,Perfil propio
    GET,/users/,company_admin,Lista usuarios (admin ve todos; company_admin ve solo su empresa)
    GET,/users/{id},company_admin,Detalle (403 si diferente empresa)
    POST,/users/,admin,Crea usuario rxcode
    POST,/users/company,company_admin,Crea editor/viewer en la empresa propia
    PATCH,/users/{id},company_admin,ActualizaciÃ³n parcial (role+company_id solo para admin)
    PATCH,/users/{id}/restore,company_admin,Reactiva usuario desactivado
    DELETE,/users/{id},company_admin,Soft delete (is_deleted=True + is_active=False)
  companies_routes[5]{method,path,auth,description}:
    GET,/companies/,admin,Lista todas las empresas
    GET,/companies/me,company_admin,Empresa propia del usuario autenticado
    GET,/companies/{id},admin,Detalle de empresa
    POST,/companies/,admin,Crea empresa
    DELETE,/companies/{id},admin,Elimina empresa
    GET,/companies/{id}/invites,admin,Lista invitaciones activas
    POST,/companies/{id}/invites,admin,Genera link de invitaciÃ³n (token)
  sites_routes[6]{method,path,auth,description}:
    GET,/sites/,user,"admin ve todos; viewer solo los suyos"
    GET,/sites/{id},user,Detalle (dueÃ±o o admin)
    POST,/sites/,user,Crea sitio del usuario actual
    PATCH,/sites/{id},user,Edita (dueÃ±o o admin)
    DELETE,/sites/{id},user,Soft delete (dueÃ±o o admin)
    PATCH,/sites/{id}/restore,user,Reactiva sitio
  proxy_routes[10]{method,path,auth,description}:
    GET,/proxy/{id}/content/{section},user,Obtiene una secciÃ³n del sitio
    GET,/proxy/{id}/colors,user,Obtiene los colores del sitio
    GET,/proxy/{id}/colors/defaults,user,Colores por defecto
    GET,/proxy/{id}/logos,user,Obtiene los logos del sitio
    PUT,/proxy/{id}/content/{section},user,Actualiza la secciÃ³n y registra historial
    PUT,/proxy/{id}/colors,user,Actualiza los colores
    PUT,/proxy/{id}/logos,user,Actualiza los logos
    DELETE,/proxy/{id}/content/{section},user,Elimina una secciÃ³n
    POST,/proxy/{id}/upload,user,Sube un archivo al sitio destino
    GET,/proxy/{id}/asset,user,Descarga un asset del sitio destino
  files_routes[3]{method,path,auth,description}:
    POST,/files/upload/image,user,"imagen png/jpg/svg/webp/gif max 2MB"
    POST,/files/upload/document,user,"documento pdf/docx max 10MB"
    POST,/files/upload/media,user,"media mp4/webm max 50MB"
  other_routes[2]{method,path,auth,description}:
    GET,/history/{id},user,Historial de cambios paginado
    GET,/health/,none,Health check
  migrations[12]: create_users,create_sites,create_refresh_tokens,create_password_reset_tokens,create_change_logs,006_sites_api_token,007_change_logs_indexes,008_sites_icon,009_add_companies,010_add_multitenancy,011_add_company_editor,012_add_is_deleted_users
  migrations_note: "12 archivos en alembic/versions/; las nuevas continÃºan desde 013"
  auth_flow:
    login: "POST /auth/login devuelve access_token + refresh_token + token_type"
    protected_header: "Authorization: Bearer <access_token>"
    access_ttl: "ACCESS_TOKEN_EXPIRE_MINUTES (default 480 min)"
    refresh_ttl: "7 dÃ­as (hardcoded)"
    refresh: "POST /auth/refresh con refresh_token devuelve nuevo access_token"
  env[10]{var,purpose}:
    APP_NAME,Nombre de la aplicaciÃ³n
    APP_VERSION,VersiÃ³n de la aplicaciÃ³n
    DEBUG,Modo debug (false en producciÃ³n)
    API_PREFIX,Prefijo de rutas (/api/v1)
    DATABASE_URL,DSN postgresql+asyncpg
    SECRET_KEY,Secreto para firmar JWT
    ALGORITHM,Algoritmo JWT (HS256)
    ACCESS_TOKEN_EXPIRE_MINUTES,ExpiraciÃ³n del access token (default 480)
    FERNET_KEY,Clave base64 url-safe para encriptar api_token
    FRONTEND_URL,Origen permitido por CORS
  conventions[7]:
    - "Todo es async: usar await y AsyncSession; nunca mezclar Session sync"
    - "Los servicios son dueÃ±os de la BD; las rutas solo orquestan"
    - "api_token siempre Fernet-encrypted al escribir y nunca en respuestas"
    - "hashed_password nunca en respuestas"
    - "Soft delete de usuarios: is_deleted=True + is_active=False; is_active solo se usa para desactivar sin eliminar"
    - "Roles via require_admin / require_company_admin a nivel de router; timestamps naive sin timezone"
    - "Pydantic v2: nunca asignar field=None en instancias de modelo; usar model_fields_set.discard() para excluir campos"

frontend:
  path: frontend/
  guide: frontend/CLAUDE.md
  stack:
    framework: Next.js 15 (App Router)
    ui: React 19 + TypeScript 5 + Tailwind v4
    dev_port: 3000
    docker_host_port: 3001
    build: "output standalone; eslint.ignoreDuringBuilds true"
  api_base_env: NEXT_PUBLIC_API_URL
  shared_design: "lenguaje visual de Rxflow (tokens CSS B/N/gris)"
  pages[6]{route,access,purpose}:
    /,user,Redirige al panel
    /login,public,Login y recuperar/resetear contraseÃ±a
    /sitios,user,Lista y CRUD de sitios
    /sitios/{id},user,Detalle con tabs Contenido/Colores/Logos/Historial
    /usuarios,company_admin,GestiÃ³n de usuarios agrupada por empresa; company_admin ve solo su grupo
    /empresas,admin,GestiÃ³n de empresas (solo rxcode admin)
  key_modules[6]{file,role}:
    src/middleware.ts,Protege rutas segÃºn la cookie rxpanel_token
    src/lib/api.ts,Cliente HTTP; extrae errores detail; logout automÃ¡tico en 401
    src/lib/auth.ts,Token y refresh en localStorage mÃ¡s cookie para el middleware
    src/store/AuthContext.tsx,Estado de sesiÃ³n (login/logout/refresh)
    src/types/api.ts,Tipos espejo de los schemas Pydantic del backend
    src/components/features/editor/SchemaEditor.tsx,Editor JSON genÃ©rico recursivo
  content_sections[10]: meta,navbar,hero,clients,services,stats,portfolio,testimonials,contact,footer
  schema_editor: "renderiza cualquier JSON del proxy: objetoâ†’grupo, arrayâ†’lista reordenable, stringâ†’input/textarea/imagen, numberâ†’input, booleanâ†’toggle; modo JSON crudo disponible"
  conventions[8]:
    - "Cero colores hardcodeados; usar siempre var(--c-*)"
    - "'use client' solo con hooks, estado o APIs del navegador"
    - "Mobile-first; las tablas se vuelven cards en mÃ³vil"
    - "Nunca <select> nativo; usar el componente SearchSelect"
    - "Botones normalizados en ui/Button (primario/ghost/danger)"
    - "types/api.ts es espejo del backend; sincronizar al cambiar un schema"
    - "Dark mode: atributo [data-theme='dark'] en <html>; Tailwind dark: NO funciona; estilos dark en globals.css bajo [data-theme='dark']"
    - "Secciones agrupadas: encabezado cyan con var(--c-section-bg/text/border); botones icono w-8 h-8 con borde"

integration:
  flow[4]:
    - "El frontend autentica en /api/v1/auth/* y guarda el JWT"
    - "CRUD de usuarios y sitios va directo a /users y /sites"
    - "Editar contenido NO toca la BD del panel: el frontend llama a /proxy/{id}/... y el backend reenvÃ­a al sitio destino usando su api_token"
    - "Cada PUT vÃ­a proxy queda registrado en change_logs (historial)"
  shared_contract: "frontend/src/types/api.ts refleja los schemas Pydantic del backend"

gotchas[8]:
  - "bcrypt anclado a <4.0.0: passlib 1.7.4 es incompatible con bcrypt 4.x (login/registro fallan con 500)"
  - "Migraciones Alembic usan SQL puro (op.execute), no op.create_table() con Enum"
  - "api_token nunca en respuestas ni logs; siempre Fernet-encrypted"
  - "Soft delete usuarios: is_deleted=True + is_active=False; list endpoints filtran is_deleted=False"
  - "Timestamps naive en BD (sin timezone); usar replace(tzinfo=None)"
  - "Frontend sin colores hardcodeados; siempre var(--c-*)"
  - "Pydantic v2: asignar field=None directamente aÃ±ade el campo a model_fields_set â†’ model_dump(exclude_unset=True) lo incluirÃ¡ con None; usar model_fields_set.discard()"
  - "Dark mode: usar [data-theme='dark'] en globals.css, NO la variante Tailwind dark:"
  - "URL base al agregar un sitio local en Docker: desde el navegador usar http://localhost:3000; desde otro contenedor Docker usar http://host.docker.internal:3000"
