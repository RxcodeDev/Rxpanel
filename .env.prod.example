# =====================================================================
# Rxpanel — Variables de entorno para PRODUCCIÓN
# Copia: cp .env.prod.example .env   (en el servidor)
# =====================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_USER=rxpanel_dba
POSTGRES_PASSWORD=CAMBIA_ESTO_contrasena_segura
POSTGRES_DB=rxpanel

# ── Backend — FastAPI ────────────────────────────────────────────────
APP_NAME=Panel API
APP_VERSION=0.1.0
DEBUG=false
API_PREFIX=/api/v1

# Genera con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_genera_con_comando_de_arriba

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Genera con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CAMBIA_ESTO_genera_con_comando_de_arriba

# ── CORS / URLs ──────────────────────────────────────────────────────
# URL pública del frontend (usada por el backend para CORS)
FRONTEND_URL=https://rxpanel.rxcode.com.mx

# NEXT_PUBLIC_API_URL se pasa como build arg en docker-compose.prod.yml,
# no se lee en runtime. Puede omitirse aquí o dejarse como referencia.
NEXT_PUBLIC_API_URL=https://rxpanel.rxcode.com.mx
