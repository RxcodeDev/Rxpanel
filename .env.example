# =====================================================
# Copia este archivo: cp .env.example .env
# Edita los valores marcados con CHANGE_ME
# =====================================================

# =====================================================
# POSTGRES — credenciales compartidas por todos los servicios
# =====================================================
POSTGRES_USER=rxpanel_dba
POSTGRES_PASSWORD=rxpanel_pass
POSTGRES_DB=rxpanel

# =====================================================
# BACKEND — FastAPI
# =====================================================
APP_NAME=Panel API
APP_VERSION=0.1.0
DEBUG=false
API_PREFIX=/api/v1

# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME

# =====================================================
# FRONTEND / CORS
# =====================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3001
