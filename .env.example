# =========================================================
# APPLICATION
# =========================================================
APP_NAME=Panel API
APP_VERSION=0.1.0
DEBUG=false
API_PREFIX=/api/v1

# =========================================================
# DATABASE
# =========================================================
# PostgreSQL + asyncpg connection string
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/panel_db

# =========================================================
# JWT AUTHENTICATION
# =========================================================
# Change this value in production
SECRET_KEY=your_super_secret_key

# JWT signing algorithm
ALGORITHM=HS256

# Access token expiration time (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# =========================================================
# SECURITY
# =========================================================
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key

# =========================================================
# CORS
# =========================================================
# Frontend application URL
FRONTEND_URL=http://localhost:3001